# Application
APP_ENV=development
LOG_LEVEL=INFO
CITADEL_PUBLIC_APP_NAME=CITADEL
CITADEL_PUBLIC_DOMAIN=Platform Engineering Knowledge
CITADEL_STORAGE_MODE=services
CITADEL_DISABLE_GENERATION=false
CITADEL_ALLOW_EXTRACTIVE_FALLBACK=true
CITADEL_QUERY_TOP_K=8
CITADEL_CONTEXT_MAX_CHUNKS=10
CITADEL_GRAPH_HOPS=1
CITADEL_RETRIEVAL_TIMEOUT_SECONDS=12
CITADEL_RERANK_TOP_K=12
CITADEL_EVAL_RECALL_THRESHOLD=0.80
CITADEL_EVAL_UNSUPPORTED_CLAIM_THRESHOLD=0.05

# API
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000
API_AUTH_MODE=disabled
API_JWT_AUDIENCE=citadel
API_JWT_ISSUER=local-dev

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Persistence
DATABASE_URL=sqlite:///./citadel.db
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=citadel_chunks
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX=citadel-documents
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=QuartzVault#81
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=citadel-password

# Providers
GENERATOR_PROVIDER=extractive
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M
